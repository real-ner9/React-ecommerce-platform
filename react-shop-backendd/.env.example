NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://shop:shop@localhost:5433/shop?schema=public
DB_SYNC=true
DB_LOGGING=true

# Docker Compose
POSTGRES_USER=shop
POSTGRES_PASSWORD=shop
POSTGRES_DB=shop

# Auth
JWT_SECRET=your-secret-jwt-key
JWT_EXPIRES_IN=1d
JWT_VERIFICATION_SECRET=your-verification-secret
JWT_VERIFICATION_EXPIRES_IN=1d

# URLs
APP_URL=http://localhost:2001

# MinIO / S3 Storage
MINIO_ENDPOINT=http://aidoll-minio-jtw20z:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=ecommerce
MINIO_USE_SSL=false

# Email (optional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=password

# Payment (optional)
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=
